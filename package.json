{
  "name": "dcrs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');function c(s,d){if(!fs.existsSync(s))return;fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){const a=p.join(s,f),b=p.join(d,f);fs.statSync(a).isDirectory()?c(a,b):fs.copyFileSync(a,b)}}c('public','.next/standalone/public');c('.next/static','.next/standalone/.next/static');fs.copyFileSync('server.js','.next/standalone/server-wrapper.js');console.log('Static assets + server wrapper copied')\"",
    "start": "node --max-old-space-size=512 .next/standalone/server-wrapper.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/suncalc": "^1.9.2",
    "animejs": "^4.4.1",
    "boneyard-js": "^1.8.1",
    "cheerio": "^1.2.0",
    "framer-motion": "^12.40.0",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^0.469.0",
    "mysql2": "^3.22.5",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sharp": "^0.33.5",
    "skillfish": "^1.0.38",
    "suncalc": "^1.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "typescript": "^5"
  },
  "overrides": {
    "react-is": "^19.0.0",
    "postcss": "^8.5.10"
  }
}
